{
  "name": "prompts-service",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["shared", "server", "client"],
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "db:push": "cd server && drizzle-kit push",
    "db:seed": "cd server && tsx src/db/seed.ts",
    "test": "npm run test --workspace=server",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "drizzle-orm": "^0.31.4"
  }
}
